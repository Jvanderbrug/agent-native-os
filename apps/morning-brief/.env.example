# Morning Brief env template. Copy to .env.local and replace each placeholder.
# Never commit a real key. .env* is gitignored. See README for 1Password and Vercel setup.

# Supabase (find these at https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# These two are also exposed to the browser. Same values as above for now.
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Telegram (talk to @BotFather first, then message your bot, then call getUpdates to grab chat_id)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
