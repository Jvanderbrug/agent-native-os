# AC Infinity grow room controller credentials
# Use the same email and password you log in to the AC Infinity mobile app with.
# Password limit: only the first 25 characters are accepted by the cloud API.
CONTROLLER_EMAIL=you@example.com
CONTROLLER_PASSWORD=replace-with-app-password

# Where the CSV log lives. Defaults to ~/Documents/grow-room/sensor-log.csv if unset.
GROW_ROOM_LOG_PATH=

# Where the rendered HTML dashboard goes. Defaults to ./dashboards/index.html if unset.
GROW_ROOM_DASHBOARD_PATH=

# Where the cached session token is stored (mode 600). Defaults to ~/.config/grow-room-monitor/token.json if unset.
GROW_ROOM_TOKEN_PATH=

# Set to "1" to use sample-data CSV instead of hitting the real cloud API. Useful for first-run smoke tests.
GROW_ROOM_USE_SAMPLE_DATA=0
